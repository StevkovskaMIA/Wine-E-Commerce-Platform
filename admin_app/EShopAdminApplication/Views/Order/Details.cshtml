@model EShopAdminApplication.Models.Order

<style>
    .product-card {
        transition: transform .2s ease, box-shadow .2s ease;
    }

        .product-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 30px rgba(0, 0, 0, .12);
        }

    .img-wrap {
        height: 320px; /* доволно висока за шише */
        background-color: #f8f9fa; /* светла позадина за празен простор околу сликата */
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        border-bottom: 1px solid #eaeaea;
    }

        .img-wrap img {
            width: 100%;
            height: 100%;
            object-fit: contain; /* цела слика, без отсекување */
            padding: 10px;
        }

    .card-body {
        text-align: center;
    }

    .clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .clamp-4 {
        display: -webkit-box;
        -webkit-line-clamp: 4;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

<div class="container my-5">
    <div class="text-center mb-4">
        <h2 class="fw-bold">Order for: @Model.User.UserName</h2>
    </div>

    <div class="row g-4">
        @foreach (var productOrder in Model.ProductInOrders)
        {
            var item = productOrder.OrderedProduct;

            <div class="col-12 col-sm-6 col-md-4 col-lg-3 d-flex">
                <div class="card product-card border-0 rounded-4 shadow-sm w-100 h-100">
                    <div class="img-wrap">
                        <img src="@item.ProductImage" alt="@item.ProductName" loading="lazy" />
                    </div>

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-semibold clamp-2">@item.ProductName</h5>
                        <p class="card-text text-muted small clamp-4">@item.ProductDescription</p>
                        <div class="mt-auto pt-2">
                            <span class="fw-bold text-danger">@item.Price ден.</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
