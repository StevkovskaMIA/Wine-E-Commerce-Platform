
@{
    ViewData["Title"] = "Reservation Confirmation";

}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 text-center p-4">
                <div class="display-1 text-success mb-3">
                    <i class="fa-solid fa-circle-check"></i>
                </div>
                <h2 class="fw-bold text-success mb-2">Резервацијата е успешна!</h2>
                <p class="text-muted mb-4">Ви благодариме за довербата. Ќе бидете известени кога ќе прифатиме.</p>
                <a href="@Url.Action("Index", "Home")" class="btn btn-primary px-4">
                    <i class="fa-solid fa-house me-2"></i>Назад кон Почетна
                </a>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
