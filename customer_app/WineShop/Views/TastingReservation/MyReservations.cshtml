@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
@model List<WineShop.Domain.DomainModels.TastingReservation>

@{
    ViewData["Title"] = "Мои дегустации";

    var upcoming = Model
        .Where(x => x.ReservationStart >= DateTime.Now && x.Status != "Cancelled")
        .OrderBy(x => x.ReservationStart)
        .ToList();

    var history = Model
        .Where(x => x.ReservationStart < DateTime.Now || x.Status == "Cancelled")
        .OrderByDescending(x => x.ReservationStart)
        .ToList();
}

<div class="container mt-5 mb-5">
    <h2 class="mb-4">Мои дегустации</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success rounded-3">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger rounded-3">@TempData["ErrorMessage"]</div>
    }

    <h4 class="mb-3">Претстојни дегустации</h4>

    @if (!upcoming.Any())
    {
        <div class="alert alert-light border rounded-3">
            Немате претстојни дегустации.
        </div>
    }
    else
    {
        <div class="row g-4 mb-5">
            @foreach (var item in upcoming)
            {
                var canCancel = (item.ReservationStart - DateTime.Now).TotalHours >= 24;

                <div class="col-md-6">
                    <div class="card shadow-sm border-0 rounded-4 h-100">
                        <div class="card-body p-4">
                            <h5 class="mb-3">@item.TastingPackage?.Name</h5>

                            <p class="mb-1"><strong>Датум:</strong> @item.ReservationStart.ToString("dd.MM.yyyy")</p>
                            <p class="mb-1"><strong>Термин:</strong> @item.ReservationStart.ToString("HH:mm")</p>
                            <p class="mb-1"><strong>Број на лица:</strong> @item.NumberOfGuests</p>
                            <p class="mb-3">
                                <strong>Статус:</strong>
                                <span class="badge bg-success">@item.Status</span>
                            </p>

                            @if (canCancel)
                            {
                                <a asp-action="Cancel"
                                   asp-route-id="@item.Id"
                                   class="btn btn-danger rounded-pill px-4">
                                    Откажи
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-secondary rounded-pill px-4" disabled>
                                    Откажување не е достапно
                                </button>

                                <p class="text-muted small mt-3 mb-0">
                                    Откажување не е можно помалку од 24 часа пред дегустацијата.
                                    За промени јавете се на <strong>+389 75 233 340</strong>.
                                </p>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <h4 class="mb-3">Историја</h4>

    @if (!history.Any())
    {
        <div class="alert alert-light border rounded-3">
            Нема претходни или откажани дегустации.
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Пакет</th>
                            <th>Датум</th>
                            <th>Термин</th>
                            <th>Лица</th>
                            <th>Статус</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in history)
                        {
                            <tr>
                                <td>@item.TastingPackage?.Name</td>
                                <td>@item.ReservationStart.ToString("dd.MM.yyyy")</td>
                                <td>@item.ReservationStart.ToString("HH:mm")</td>
                                <td>@item.NumberOfGuests</td>
                                <td>
                                    @if (item.Status == "Cancelled")
                                    {
                                        <span class="badge bg-danger">Откажи</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Completed / Past</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>