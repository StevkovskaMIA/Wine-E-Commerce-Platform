@model WineShop.Domain.DTO.ShoppingCartDto
@using WineShop.Domain.Payment
@using Microsoft.Extensions.Options
@inject IOptions<StripeSettings> Stripe

@{
    ViewData["Title"] = "Shopping Cart";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4 cart-page">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="h3 fw-bold m-0">Кошничка</h1>
        <a asp-controller="Products" asp-action="Index" class="btn btn-light">
            ← Продолжи со купување
        </a>
    </div>

    @if (!Model.Products.Any())
    {
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5 text-center">
                <div class="display-6 mb-3">🧺</div>
                <h2 class="h4 fw-bold">Кошничката е празна</h2>
                <p class="text-muted mb-4">Додај производи за да продолжиш кон плаќање.</p>
                <a asp-controller="Products" asp-action="Index" class="btn btn-primary">
                    Разгледај производи
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Листа на артикли -->
            <div class="col-12 col-lg-8">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table align-middle cart-table m-0">
                                <thead class="table-light">
                                    <tr>
                                        <th scope="col" class="ps-4">Производ</th>
                                        <th scope="col">Цена</th>
                                        <th scope="col" style="width:140px;">Количина</th>
                                        <th scope="col" class="text-end pe-4">Меѓузбир</th>
                                        <th scope="col" class="text-end pe-4">Акција</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.Products.Count; i++)
                                    {
                                        var item = Model.Products[i];
                                        var price = item.Product.Price;
                                        var qty = item.Quantity;
                                        var subtotal = price * qty;
                                        <tr>
                                            <td class="ps-4">
                                                <div class="d-flex align-items-center gap-3">
                                                    <img src="@item.Product.ProductImage"
                                                         alt="@item.Product.ProductName"
                                                         class="cart-thumb rounded" />
                                                    <div>
                                                        <div class="fw-semibold">@item.Product.ProductName</div>
                                                        <div class="text-muted small line-clamp-1">
                                                            @item.Product.ProductDescription
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="fw-semibold">@String.Format("{0:n0}", price) <span class="text-muted">ден</span></div>
                                            </td>
                                            <td>
                                                <div class="input-group input-group-sm qty-group">
                                                    <input class="form-control text-center" value="@qty" readonly />
                                                </div>
                                            </td>
                                            <td class="text-end pe-4">
                                                <div class="fw-bold">@String.Format("{0:n0}", subtotal) <span class="text-muted">ден</span></div>
                                            </td>
                                            <td class="text-end pe-4">
                                                <a asp-controller="ShoppingCart"
                                                   asp-action="DeleteFromShoppingCart"
                                                   asp-route-id="@item.ProductId"
                                                   class="btn btn-sm btn-outline-danger">
                                                    <i class="fa-solid fa-trash-can me-1"></i>Избриши
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-light">
                                    <tr>
                                        <th class="ps-4">Вкупно</th>
                                        <th></th>
                                        <th></th>
                                        <th class="text-end pe-4">
                                            <div class="h5 m-0 fw-bold">
                                                @String.Format("{0:n0}", Model.TotalPrice) <span class="text-muted">ден</span>
                                            </div>
                                        </th>
                                        <th></th>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Резиме / Checkout -->
            <div class="col-12 col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 position-sticky summary-card">
                    <div class="card-body p-4">
                        <h2 class="h5 fw-bold mb-3">Резиме на нарачка</h2>

                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Производи</span>
                            <span>@Model.Products.Count</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Вкупно</span>
                            <span class="fw-semibold">@String.Format("{0:n0}", Model.TotalPrice) ден</span>
                        </div>

                        <hr class="my-3" />

                        <!-- НАЧИН НА ДОСТАВА -->
                        <h3 class="h6 fw-semibold mb-2">Начин на достава</h3>
                        <div class="delivery-options mb-3">
                            <label class="delivery-option-card">
                                <input type="radio" name="deliveryType" value="pickup" id="opt-pickup" checked />
                                <div class="delivery-option-inner">
                                    <span class="option-icon"><i class="fa-solid fa-store"></i></span>
                                    <div>
                                        <div class="fw-semibold small">Лично превземање</div>
                                        <div class="text-muted" style="font-size:.75rem;">Подигни нарачката во продавница</div>
                                    </div>
                                </div>
                            </label>
                            <label class="delivery-option-card">
                                <input type="radio" name="deliveryType" value="delivery" id="opt-delivery" />
                                <div class="delivery-option-inner">
                                    <span class="option-icon"><i class="fa-solid fa-truck"></i></span>
                                    <div>
                                        <div class="fw-semibold small">Достава</div>
                                        <div class="text-muted" style="font-size:.75rem;">Испорака на адреса</div>
                                    </div>
                                </div>
                            </label>
                        </div>

                        <!-- Телефон - секогаш -->
                        <div class="mb-3">
                            <label for="deliveryPhone" class="form-label small fw-semibold mb-1">
                                <i class="fa-solid fa-phone me-1 text-muted"></i>Мобилен телефон
                            </label>
                            <input type="tel"
                                   id="deliveryPhone"
                                   class="form-control form-control-sm"
                                   placeholder="+389 7X XXX XXX или 07X XXX XXX"
                                   maxlength="20"
                                   pattern="^(\+389\s?7\d\s?\d{3}\s?\d{3}|07\d\s?\d{3}\s?\d{3})$" />
                        </div>

                        <!-- Адреса и град - само при достава -->
                        <div id="delivery-fields" class="delivery-address-box mb-3" style="display:none;">
                            <div class="mb-2">
                                <label for="deliveryAddress" class="form-label small fw-semibold mb-1">
                                    <i class="fa-solid fa-location-dot me-1 text-muted"></i>Адреса
                                </label>
                                <input type="text" id="deliveryAddress" class="form-control form-control-sm"
                                       placeholder="ул. Македонија бр. 1" maxlength="200" />
                            </div>

                            <div class="mb-2">
                                <label for="deliveryCity" class="form-label small fw-semibold mb-1">
                                    <i class="fa-solid fa-city me-1 text-muted"></i>Град
                                </label>
                                <input type="text" id="deliveryCity" class="form-control form-control-sm"
                                       placeholder="Скопје" maxlength="100" />
                            </div>
                        </div>

                        <div id="delivery-validation-msg" class="text-danger small mt-2" style="display:none;">
                            <i class="fa-solid fa-circle-exclamation me-1"></i>
                            Внеси валиден телефон: +389 7X XXX XXX или 07X XXX XXX. За достава внеси и адреса со град.
                        </div>

                        <hr class="my-3" />

                        <!-- НАЧИН НА ПЛАЌАЊЕ -->
                        <h3 class="h6 fw-semibold mb-2">Начин на плаќање</h3>
                        <div class="payment-options mb-3">
                            <!-- Активна опција -->
                            <label class="payment-option-card">
                                <input type="radio" name="paymentType" value="cod" id="opt-cod" checked />
                                <div class="payment-option-inner">
                                    <span class="option-icon"><i class="fa-solid fa-money-bill-wave"></i></span>
                                    <div>
                                        <div class="fw-semibold small">Плаќање при превземање</div>
                                        <div class="text-muted" style="font-size:.75rem;">Готовина или картица при испорака</div>
                                    </div>
                                </div>
                            </label>

                            <!-- Оневозможена опција -->
                            <div class="payment-option-card payment-option-disabled"
                                 title="Ова плаќање наскоро ќе биде достапно">
                                <div class="payment-option-inner">
                                    <span class="option-icon"><i class="fa-solid fa-credit-card"></i></span>
                                    <div>
                                        <div class="fw-semibold small">
                                            Картица (онлајн)
                                            <span class="badge bg-secondary ms-1" style="font-size:.6rem; vertical-align:middle;">Наскоро</span>
                                        </div>
                                        <div class="text-muted" style="font-size:.75rem;">Stripe — безбедно онлајн плаќање</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="my-3" />

                        <!-- Копче за нарачка -->
                        <button id="checkout-button" class="btn btn-primary w-100 btn-lg">
                            <i class="fa-solid fa-bag-shopping me-2"></i>
                            Нарачај @String.Format("{0:n0}", Model.TotalPrice) ден
                        </button>

                        <p class="text-muted small mt-2 mb-0 text-center">
                            <i class="fa-solid fa-lock me-1"></i>Сигурна нарачка
                        </p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- ══════════════════════════════════════
     МОДАЛ ЗА ПОТВРДА НА НАРАЧКА
══════════════════════════════════════ -->
<div class="modal fade" id="confirmOrderModal" tabindex="-1"
     aria-labelledby="confirmOrderLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="confirmOrderLabel">
                    <i class="fa-solid fa-clipboard-check me-2 text-primary"></i>Потврди нарачка
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Затвори"></button>
            </div>
            <div class="modal-body pt-3">
                <div id="modal-order-summary"></div>
            </div>
            <div class="modal-footer border-0 pt-0 gap-2">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Назад</button>
                <button type="button" class="btn btn-primary px-4" id="confirm-order-btn">
                    <i class="fa-solid fa-check me-1"></i>Потврди и нарачај
                </button>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<style>
    .cart-page .cart-thumb {
        width: 72px;
        height: 72px;
        object-fit: contain;
        background: #fff;
        box-shadow: 0 4px 12px rgba(0,0,0,.05);
    }

    .cart-table tbody tr + tr td {
        border-top: 1px solid #f1f3f5;
    }

    .line-clamp-1 {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .qty-group input {
        max-width: 80px;
    }

    .summary-card {
        top: 16px;
    }

    /* ── Опции (достава + плаќање) ── */
    .delivery-options, .payment-options {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .delivery-option-card, .payment-option-card {
        display: block;
        border: 1.5px solid #dee2e6;
        border-radius: 10px;
        padding: 10px 12px;
        cursor: pointer;
        transition: border-color .15s, background .15s, box-shadow .15s;
        background: #fff;
        user-select: none;
    }

        .delivery-option-card:hover {
            border-color: #adb5bd;
            background: #f8f9fa;
        }

        .delivery-option-card:has(input:checked) {
            border-color: #0d6efd;
            background: #f0f5ff;
            box-shadow: 0 0 0 3px rgba(13,110,253,.1);
        }

            .delivery-option-card:has(input:checked) .option-icon {
                background: #0d6efd;
                color: #fff;
            }

    .payment-option-card {
        cursor: default;
    }

        .payment-option-card:has(input:checked) {
            border-color: #0d6efd;
            background: #f0f5ff;
            box-shadow: 0 0 0 3px rgba(13,110,253,.1);
        }

            .payment-option-card:has(input:checked) .option-icon {
                background: #0d6efd;
                color: #fff;
            }

    .payment-option-disabled {
        opacity: 0.5;
        background: #f8f9fa !important;
        border-color: #e9ecef !important;
        cursor: not-allowed !important;
    }

    .delivery-option-inner, .payment-option-inner {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .delivery-option-card input, .payment-option-card input {
        display: none;
    }

    .option-icon {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        background: #f1f3f5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .9rem;
        color: #495057;
        flex-shrink: 0;
        transition: background .15s, color .15s;
    }

    /* ── Поле за адреса ── */
    .delivery-address-box {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 10px;
        padding: 12px;
        animation: slideDown .2s ease;
    }
    @@keyframes slideDown {
        from

    {
        opacity: 0;
        transform: translateY(-6px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    /* ── Модал резиме ── */
    .modal-summary-row {
        display: flex;
        justify-content: space-between;
        padding: 7px 0;
        font-size: .9rem;
    }

        .modal-summary-row + .modal-summary-row {
            border-top: 1px solid #f1f3f5;
        }

    .modal-summary-label {
        color: #6c757d;
    }

    .modal-summary-value {
        font-weight: 500;
    }

    .modal-summary-total .modal-summary-label,
    .modal-summary-total .modal-summary-value {
        font-weight: 700;
        font-size: 1rem;
    }
</style>

<script src="https://js.stripe.com/v3/"></script>
<script src="https://js.stripe.com/v3/"></script>
<script>
    (function () {
        const optPickup = document.getElementById('opt-pickup');
        const optDelivery = document.getElementById('opt-delivery');
        const deliveryFields = document.getElementById('delivery-fields');
        const addrInput = document.getElementById('deliveryAddress');
        const cityInput = document.getElementById('deliveryCity');
        const phoneInput = document.getElementById('deliveryPhone');
        const validationMsg = document.getElementById('delivery-validation-msg');
        const checkoutBtn = document.getElementById('checkout-button');
        const confirmBtn = document.getElementById('confirm-order-btn');
        const modalEl = document.getElementById('confirmOrderModal');
        const summaryEl = document.getElementById('modal-order-summary');

        const phoneRegex = /^(\+389\s?7\d\s?\d{3}\s?\d{3}|07\d\s?\d{3}\s?\d{3})$/;

        function toggleDeliveryFields() {
            const show = optDelivery && optDelivery.checked;

            if (deliveryFields) {
                deliveryFields.style.display = show ? 'block' : 'none';
            }

            if (!show) {
                addrInput?.classList.remove('is-invalid');
                cityInput?.classList.remove('is-invalid');
            }

            phoneInput?.classList.remove('is-invalid');

            if (validationMsg) {
                validationMsg.style.display = 'none';
            }
        }

        if (optPickup) optPickup.addEventListener('change', toggleDeliveryFields);
        if (optDelivery) optDelivery.addEventListener('change', toggleDeliveryFields);

        toggleDeliveryFields();

        if (checkoutBtn) {
            checkoutBtn.addEventListener('click', function () {
                const isDelivery = optDelivery && optDelivery.checked;
                const addr = addrInput ? addrInput.value.trim() : '';
                const city = cityInput ? cityInput.value.trim() : '';
                const phone = phoneInput ? phoneInput.value.trim() : '';

                let hasError = false;

                if (!phoneRegex.test(phone)) {
                    hasError = true;
                    phoneInput?.classList.add('is-invalid');
                } else {
                    phoneInput?.classList.remove('is-invalid');
                }

                if (isDelivery) {
                    if (!addr) {
                        hasError = true;
                        addrInput?.classList.add('is-invalid');
                    } else {
                        addrInput?.classList.remove('is-invalid');
                    }

                    if (!city) {
                        hasError = true;
                        cityInput?.classList.add('is-invalid');
                    } else {
                        cityInput?.classList.remove('is-invalid');
                    }
                } else {
                    addrInput?.classList.remove('is-invalid');
                    cityInput?.classList.remove('is-invalid');
                }

                if (hasError) {
                    if (validationMsg) validationMsg.style.display = 'block';
                    phoneInput?.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    return;
                }

                if (validationMsg) validationMsg.style.display = 'none';

                const deliveryText = isDelivery ? 'Достава' : 'Лично превземање';

                const phoneLine = `
                    <div class="modal-summary-row">
                        <span class="modal-summary-label">Телефон</span>
                        <span class="modal-summary-value">${esc(phone)}</span>
                    </div>
                `;

                const addrLine = isDelivery ? `
                    <div class="modal-summary-row">
                        <span class="modal-summary-label">Адреса</span>
                        <span class="modal-summary-value">${esc(addr)}</span>
                    </div>
                    <div class="modal-summary-row">
                        <span class="modal-summary-label">Град</span>
                        <span class="modal-summary-value">${esc(city)}</span>
                    </div>
                ` : '';

                if (summaryEl) {
                    summaryEl.innerHTML = `
                        <div class="modal-summary-row">
                            <span class="modal-summary-label">Начин на достава</span>
                            <span class="modal-summary-value">${deliveryText}</span>
                        </div>
                        ${phoneLine}
                        ${addrLine}
                        <div class="modal-summary-row">
                            <span class="modal-summary-label">Плаќање</span>
                            <span class="modal-summary-value">Плаќање при превземање</span>
                        </div>
                    `;
                }

                if (modalEl && window.bootstrap) {
                    const modal = new bootstrap.Modal(modalEl);
                    modal.show();
                } else {
                    alert('Не може да се отвори прозорецот за потврда.');
                }
            });
        }

        if (confirmBtn) {
            confirmBtn.addEventListener('click', function () {
                confirmBtn.disabled = true;
                confirmBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Се обработува…';

                const payload = {
                    deliveryType: (optDelivery && optDelivery.checked) ? 'delivery' : 'pickup',
                    address: (optDelivery && optDelivery.checked) ? addrInput?.value.trim() : null,
                    city: (optDelivery && optDelivery.checked) ? cityInput?.value.trim() : null,
                    phone: phoneInput ? phoneInput.value.trim() : null
                };

                fetch('/ShoppingCart/PlaceOrderWithDelivery', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': getCsrfToken()
                    },
                    body: JSON.stringify(payload)
                })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        window.location.href = '/ShoppingCart/SuccessPayment';
                    } else {
                        alert(data.message || 'Настана грешка. Обиди се повторно.');
                        confirmBtn.disabled = false;
                        confirmBtn.innerHTML = '<i class="fa-solid fa-check me-1"></i>Потврди и нарачај';
                    }
                })
                .catch(() => {
                    alert('Грешка при поврзување. Провери ја интернет врската.');
                    confirmBtn.disabled = false;
                    confirmBtn.innerHTML = '<i class="fa-solid fa-check me-1"></i>Потврди и нарачај';
                });
            });
        }

        function getCsrfToken() {
            const el = document.querySelector('input[name="__RequestVerificationToken"]');
            return el ? el.value : '';
        }

        function esc(s) {
            return String(s || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;');
        }
    })();
</script>