@{
    ViewData["Title"] = "Payment Failed";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 text-center p-4">
                <div class="display-1 text-danger mb-3">
                    <i class="fa-solid fa-circle-xmark"></i>
                </div>
                <h2 class="fw-bold text-danger mb-2">Плаќањето не успеа</h2>
                <p class="text-muted mb-4">За жал, трансакцијата не беше успешна. Провери ги твоите податоци и обиди се повторно.</p>
                <a href="@Url.Action("Index", "ShoppingCart")" class="btn btn-warning px-4">
                    <i class="fa-solid fa-rotate-right me-2"></i>Обиди се повторно
                </a>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
