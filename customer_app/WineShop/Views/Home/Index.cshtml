@model WineShop.Domain.DTO.HomePageViewModel

@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- HERO (slideshow) -->
<section class="hero-section d-flex align-items-center text-center text-white"
         data-hero-images="logo1.jpg,logo2.jpg,logo3.jpg"
         data-hero-interval="10000">
    <div class="hero-bg"></div>
    <div class="hero-bg-next"></div>

    <div class="container position-relative">
        <h1 class="display-4 fw-bold">Винарија Традиција</h1>
        <p class="lead mb-4">
            Откријте ги најдобрите вина од нашата колекција и доживејте незаборавни дегустации во срцето на винската традиција.
        </p>
        <a href="#reserve" class="btn btn-primary btn-lg me-2">Резервирај дегустација</a>
        <a asp-controller="Products" asp-action="Index" class="btn btn-outline-light btn-lg">Погледни колекција</a>
    </div>
</section>

<!-- RESERVE -->
<section id="reserve" class="py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge bg-white text-muted border">Вински дегустации</span>
            <h2 class="fw-bold mt-2">Доживејте го вистинскиот вкус</h2>
            <p class="text-muted mb-0">
                Нашите стручни сомелиери ќе ве водат низ патување на вкусови и ароми, откривајќи ги тајните на секое вино од нашата внимателно селектирана колекција.
            </p>
        </div>

        <div class="row g-4 justify-content-center">
            @foreach (var item in Model.TastingPackages)
            {
                <div class="col-md-6 col-lg-5">
                    <div class="card h-100 shadow-sm @(item.BlocksWholeDay ? "border-warning premium-ring" : "border-0") hover-raise">
                        <div class="card-body p-4 position-relative">
                            @if (item.BlocksWholeDay)
                            {
                                <span class="badge bg-warning-subtle text-warning-emphasis border position-absolute top-0 start-50 translate-middle px-3 rounded-pill">
                                    Најпопуларно
                                </span>
                            }

                            <h4 class="fw-bold @(item.BlocksWholeDay ? "mt-3" : "") mb-1">@item.Name</h4>
                            <p class="text-muted small mb-3">@item.Description</p>

                            <div class="d-flex gap-4 small text-muted mb-3">
                                <div><i class="bi bi-clock me-1"></i>@item.DurationHours часа</div>
                                <div><i class="bi bi-people me-1"></i>До @item.MaxGuests лица</div>
                            </div>

                            @if (item.BlocksWholeDay)
                            {
                                <ul class="list-unstyled small mb-4">
                                    <li>• Водена тура низ винарија</li>
                                    <li>• Презентација на производство на вино</li>
                                    <li>• Демонстрација на традиционален метод за пенливо вино</li>
                                    <li>• Богата гурме дегустација на храна и вино</li>
                                    <li>• Ексклузивно: го блокира целиот ден</li>
                                </ul>
                            }
                            else
                            {
                                <ul class="list-unstyled small mb-4">
                                    <li>• Прошетка низ винарија</li>
                                    <li>• Дегустација на вино</li>
                                    <li>• Храна на даска</li>
                                    <li>• Минимум 3 часа простор меѓу термини</li>
                                </ul>
                            }

                            <div class="d-flex align-items-center justify-content-between">
                                <div class="h4 fw-bold mb-0">@item.Price ден</div>
                                <a asp-controller="TastingReservation"
                                   asp-action="Book"
                                   asp-route-packageId="@item.Id"
                                   class="btn btn-danger">
                                    Резервирај термин
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- FEATURED WINES -->
<section id="wines" class="featured-section py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mb-0">Наши вина</h2>
            <a asp-controller="Products" asp-action="Index">See all →</a>
        </div>

        <div class="row g-4">
            @foreach (var item in Model.Products)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <a asp-controller="Products"
                       asp-action="Details"
                       asp-route-id="@item.Id"
                       class="wine-card text-decoration-none">
                        <div class="card h-100 shadow-sm d-flex flex-column">
                            <img src="@item.ProductImage" class="card-img-top" alt="@item.ProductName" />

                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title mb-1">@item.ProductName</h5>
                                <p class="card-text text-muted mb-2 desc-clamp-2">@item.ProductDescription</p>
                                <strong class="text-dark mt-auto">@item.Price ден</strong>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
</section>

<section id="visit" class="visit-section py-5">
    <div class="container">
        <div class="row g-4 align-items-start">
            <div class="col-12 col-lg-5">
                <h2 class="display-6 fw-bold mb-2">За нас</h2>
                <p class="text-muted mb-4">Отворени секој ден од 10:00 до 22:00. Препорачуваме резервација за време на викендите.</p>

                <dl class="mb-4">
                    <dt class="fw-semibold">Адреса:</dt>
                    <dd class="mb-2">Македонска Преродба 6p.70, Скопје</dd>

                    <dt class="fw-semibold">Контакт:</dt>
                    <dd class="mb-2"><a class="text-decoration-none" href="tel:+38975233340">+389 75 233 340</a></dd>
                    <dd class="mb-2"><a class="text-decoration-none" href="tel:+38970233340">+389 75 233 340</a></dd>

                    <dt class="fw-semibold">Е-пошта:</dt>
                    <dd><a class="text-decoration-none" href="mailto:contact@winerykuvin.com">contact@winerykuvin.com</a></dd>
                </dl>

                <div class="d-flex gap-2">
                    <a href="tel:+38975233340" class="btn btn-primary">Call</a>
                    <a href="mailto:contact@winerykuvin.com" class="btn btn-outline-secondary">Email</a>
                </div>
            </div>

            <div class="col-12 col-lg-7">
                <div class="map-box shadow-sm rounded-4 position-relative">
                    <div class="ratio ratio-16x9">
                        <iframe class="gmap"
                                src="https://www.google.com/maps?q=42.0094835,21.351241&hl=mk&z=17&output=embed"
                                allowfullscreen
                                loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade"
                                title="Winery Kuvin on map"></iframe>
                    </div>

                    <div class="map-actions">
                        <a class="btn btn-light btn-sm"
                           href="https://www.google.com/maps/place/Winery+Kuvin/"
                           target="_blank" rel="noopener"></a>
                        <a class="btn btn-outline-primary btn-sm"
                           href="https://www.google.com/maps/dir/?api=1&destination=42.0094835,21.351241"
                           target="_blank" rel="noopener">Directions</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    :root {
        --nav-offset: 80px;
    }

    #visit {
        scroll-margin-top: var(--nav-offset);
    }

    .visit-section {
        background: #fff;
    }

    .map-box {
        border: 1px solid #eef1f4;
    }

    .gmap {
        width: 100%;
        height: 100%;
        border: 0;
        pointer-events: auto !important;
    }

    .map-actions {
        position: absolute;
        right: 10px;
        top: 10px;
        z-index: 2;
        display: flex;
        gap: .5rem;
        backdrop-filter: blur(6px);
    }

    .hero-section {
        position: relative;
        min-height: 85vh;
        padding-top: 96px;
        overflow: hidden;
    }

        .hero-section .hero-bg,
        .hero-section .hero-bg-next {
            position: absolute;
            inset: 0;
            background-position: center;
            background-size: cover;
            background-repeat: no-repeat;
            background-attachment: fixed;
            transition: opacity 1s ease-in-out, transform 1s ease-in-out;
        }

        .hero-section .hero-bg {
            opacity: 1;
            transform: scale(1);
        }

        .hero-section .hero-bg-next {
            opacity: 0;
            transform: scale(1.02);
        }

        .hero-section .container {
            position: relative;
            z-index: 2;
        }

        .hero-section .hero-bg:before,
        .hero-section .hero-bg-next:before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(rgba(0,0,0,.35), rgba(0,0,0,.35));
        }

    .hover-raise {
        transition: transform .2s, box-shadow .2s;
    }

        .hover-raise:hover {
            transform: translateY(-4px);
            box-shadow: 0 12px 28px rgba(0,0,0,.12);
        }

    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    #mainNav .nav-link {
        padding: .5rem .8rem;
    }

    .featured-card img {
        height: 200px;
        object-fit: contain;
        background: #fff;
    }

    .featured-card .card-body {
        padding: 1rem;
    }

    .featured-card h5 {
        font-size: 1rem;
        margin-bottom: .25rem;
    }

    .featured-card p {
        font-size: 0.9rem;
    }

    .featured-section {
        background-color: #f8f9fa;
    }

    .featured-card img {
        height: 200px;
        object-fit: contain;
        background: #fff;
    }

    .featured-card .card-body {
        padding: 1rem;
    }

    .wine-card {
        display: block;
        color: inherit;
        transition: transform .18s ease, box-shadow .18s ease;
    }

        .wine-card .card {
            border-radius: 12px;
            overflow: hidden;
            transition: inherit;
        }

        .wine-card:hover .card,
        .wine-card:focus .card {
            transform: translateY(-4px);
            box-shadow: 0 8px 20px rgba(0,0,0,.12);
            text-decoration: none;
        }

        .wine-card img {
            height: 200px;
            object-fit: contain;
            background: #fff;
        }

        .wine-card .card {
            border-radius: 12px;
            overflow: hidden;
        }

        .wine-card .card-body {
            padding: 1rem;
        }

    .desc-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.4;
        min-height: calc(1em * 1.4 * 2);
    }

    .desc-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        line-height: 1.4;
        min-height: calc(1em * 1.4 * 3);
    }

    .wine-card {
        transition: transform .18s, box-shadow .18s;
        display: block;
        color: inherit;
    }

        .wine-card:hover .card {
            transform: translateY(-4px);
            box-shadow: 0 8px 20px rgba(0,0,0,.12);
        }
</style>

<script>
    (function(){
      const hero = document.querySelector('.hero-section');
      if(!hero) return;

      let images = ['logo1.jpg','logo2.jpg','logo3.jpg'].map(p => `/images/${p}`);
      const intervalMs = 10000;

      const bgA = hero.querySelector('.hero-bg');
      const bgB = hero.querySelector('.hero-bg-next');

      const preload = src => { const i = new Image(); i.src = src; };

      let idx = 0;
      function setBg(el, src){ el.style.backgroundImage = `url('${src}')`; }

      setBg(bgA, images[0]);
      preload(images[1 % images.length]);

      let usingAOnTop = true;
      let timerId = null;

      function tick(){
        idx = (idx + 1) % images.length;
        const nextSrc = images[idx];

        const topEl = usingAOnTop ? bgA : bgB;
        const underEl = usingAOnTop ? bgB : bgA;

        setBg(underEl, nextSrc);
        underEl.style.opacity = '1';
        underEl.style.transform = 'scale(1)';
        topEl.style.opacity = '0';
        topEl.style.transform = 'scale(1.02)';

        usingAOnTop = !usingAOnTop;

        const nextIdx = (idx + 1) % images.length;
        preload(images[nextIdx]);
      }

      function start(){ if(!timerId) timerId = setInterval(tick, intervalMs); }
      function stop(){ if(timerId){ clearInterval(timerId); timerId = null; } }

      start();
      document.addEventListener('visibilitychange', () => {
        if(document.hidden) stop(); else start();
      });
    })();
</script>