@model WineShop.Domain.DomainModels.Product

@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h1 class="h3 mb-1">Create</h1>
            <div class="text-muted">Product</div>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">← Back to List</a>
    </div>

    @Html.ValidationSummary("", new { @class = "text-danger small mb-3" })

    <div class="row g-4">
        <!-- LEFT: Image Preview -->
        <div class="col-lg-5">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-3">
                    <div class="preview-wrap">
                        <img id="productPreview"
                             src="https://via.placeholder.com/800x600?text=Preview+Image"
                             alt="Product image"
                             class="img-fluid rounded-3 preview-image"
                             role="button"
                             data-bs-toggle="modal"
                             data-bs-target="#imageModal" />
                    </div>
                    <div class="small text-muted mt-2">
                        Кликни на сликата за да ја видиш поголема.
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 rounded-4 mt-4">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-3 text-wine">Преглед</h4>

                    <div class="text-center mb-3">
                        <img id="sidePreview"
                             src="https://via.placeholder.com/800x600?text=Preview+Image"
                             alt="Preview"
                             class="img-fluid rounded-4 preview-side-image" />
                    </div>

                    <p class="text-muted mb-0">
                        Наградите не се додаваат при креирање. Прво креирај го виното, па после во <strong>Edit</strong> можеш да додадеш една или повеќе награди.
                    </p>
                </div>
            </div>
        </div>

        <!-- RIGHT: Form -->
        <div class="col-lg-7">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <form asp-action="Create" method="post" class="needs-validation" novalidate>
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                        <div class="mb-3">
                            <label asp-for="ProductName" class="form-label fw-semibold">Product Name</label>
                            <input asp-for="ProductName" class="form-control form-control-lg" placeholder="Пр. Merlot" />
                            <span asp-validation-for="ProductName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ProductImage" class="form-label fw-semibold">Product Image URL</label>
                            <input asp-for="ProductImage" class="form-control" id="imageUrlInput" placeholder="https://..." />
                            <span asp-validation-for="ProductImage" class="text-danger"></span>
                            <div class="form-text">Внеси валидно URL. Preview-то лево се освежува веднаш.</div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ProductDescription" class="form-label fw-semibold">Description</label>
                            <textarea asp-for="ProductDescription" class="form-control" rows="3" placeholder="Краток опис"></textarea>
                            <span asp-validation-for="ProductDescription" class="text-danger"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-4">
                                <label asp-for="Price" class="form-label fw-semibold">Price</label>
                                <div class="input-group">
                                    <span class="input-group-text">ден</span>
                                    <input asp-for="Price" class="form-control" inputmode="numeric" />
                                </div>
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Rating" class="form-label fw-semibold">Rating (0–5)</label>
                                <select asp-for="Rating" class="form-select">
                                    @for (var r = 0; r <= 5; r++)
                                    {
                                        <option value="@r">@r</option>
                                    }
                                </select>
                                <span asp-validation-for="Rating" class="text-danger"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Quantity" class="form-label fw-semibold">Quantity</label>
                                <input asp-for="Quantity" class="form-control" inputmode="numeric" />
                                <span asp-validation-for="Quantity" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Color" class="form-label fw-semibold">Color</label>
                                <select asp-for="Color" class="form-select">
                                    <option value="">Избери боја</option>
                                    <option value="Red">Red</option>
                                    <option value="White">White</option>
                                    <option value="Rose">Rose</option>
                                    <option value="Sparkling">Sparkling</option>
                                </select>
                                <span asp-validation-for="Color" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Year" class="form-label fw-semibold">Year</label>
                                <input asp-for="Year" type="number" class="form-control" placeholder="Пр. 2023" />
                                <span asp-validation-for="Year" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary px-4">Create</button>
                            <a asp-action="Index" class="btn btn-light">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Image Modal -->
<div class="modal fade" id="imageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content border-0">
            <div class="modal-body p-0">
                <img id="productPreviewModal"
                     src="https://via.placeholder.com/1400x900?text=Preview+Image"
                     alt="Product image large"
                     class="w-100 h-auto rounded-3" />
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Затвори</button>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<style>
    .text-wine {
        color: #7b2d33;
    }

    .preview-wrap {
        background: #f8f9fa;
        border-radius: 14px;
        padding: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 360px;
    }

    .preview-image {
        max-height: 520px;
        object-fit: contain;
        transition: transform .2s ease;
        cursor: zoom-in;
    }

        .preview-image:hover {
            transform: scale(1.01);
            box-shadow: 0 12px 28px rgba(0,0,0,.12);
        }

    .preview-side-image {
        max-height: 240px;
        object-fit: contain;
        background: #fff;
        border: 1px solid #f1f1f1;
        padding: 12px;
    }

    .form-label {
        margin-bottom: .35rem;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        (function(){
            const input = document.getElementById('imageUrlInput');
            const preview = document.getElementById('productPreview');
            const previewModal = document.getElementById('productPreviewModal');
            const sidePreview = document.getElementById('sidePreview');

            function isHttpUrl(u){ return /^https?:\/\/.+/i.test(u || ""); }

            function setImg(img, url, fallback){
                if (!img) return;
                img.src = isHttpUrl(url) ? url : fallback;
            }

            const fallbackSmall = 'https://via.placeholder.com/800x600?text=Preview+Image';
            const fallbackLarge = 'https://via.placeholder.com/1400x900?text=Preview+Image';

            if (input) {
                input.addEventListener('input', () => {
                    const url = input.value?.trim();
                    setImg(preview, url, fallbackSmall);
                    setImg(previewModal, url, fallbackLarge);
                    setImg(sidePreview, url, fallbackSmall);
                });
            }

            if (preview) {
                preview.addEventListener('error', () => setImg(preview, null, fallbackSmall));
            }

            if (previewModal) {
                previewModal.addEventListener('error', () => setImg(previewModal, null, fallbackLarge));
            }

            if (sidePreview) {
                sidePreview.addEventListener('error', () => setImg(sidePreview, null, fallbackSmall));
            }
        })();
    </script>
}