@model WineShop.Domain.DomainModels.Product

@{
    ViewData["Title"] = "Edit";
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h1 class="h3 mb-1">Edit</h1>
            <div class="text-muted">Product</div>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">← Back to List</a>
    </div>

    <div class="row g-4">
        <!-- LEFT: Image Preview -->
        <div class="col-lg-5">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-3">
                    <div class="preview-wrap">
                        <img id="productPreview"
                             src="@(string.IsNullOrWhiteSpace(Model?.ProductImage) ? "https://via.placeholder.com/800x600?text=No+Image" : Model.ProductImage)"
                             alt="Product image"
                             class="img-fluid rounded-3 preview-image"
                             role="button"
                             data-bs-toggle="modal"
                             data-bs-target="#imageModal" />
                    </div>
                    <div class="small text-muted mt-2">
                        Кликни на сликата за да ја видиш поголема.
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 rounded-4 mt-4">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-3 text-wine">Награди и признанија</h4>

                    @if (Model.ProductAwards != null && Model.ProductAwards.Any())
                    {
                        <div class="table-responsive mb-4">
                            <table class="table align-middle">
                                <thead>
                                    <tr>
                                        <th>Натпревар</th>
                                        <th>Награда</th>
                                        <th>Година</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var award in Model.ProductAwards)
                                    {
                                        <tr>
                                            <td>@award.CompetitionName</td>
                                            <td>
                                                @switch (award.AwardName)
                                                {
                                                    case "Gold":
                                                        @:Златна
                                                        break;
                                                    case "Silver":
                                                        @:Сребрена
                                                        break;
                                                    case "Bronze":
                                                        @:Бронзена
                                                        break;
                                                    case "Best of Show":
                                                        @:Best of Show
                                                        break;
                                                    default:
                                                        @award.AwardName
                                                        break;
                                                }
                                            </td>
                                            <td>@award.AwardYear</td>
                                            <td class="text-end">
                                                <form asp-action="DeleteAward" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="awardId" value="@award.Id" />
                                                    <input type="hidden" name="productId" value="@Model.Id" />
                                                    <button type="submit" class="btn btn-sm btn-danger rounded-pill">
                                                        Избриши
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">Нема внесени награди за ова вино.</p>
                    }

                    <hr class="my-4" />

                    <h5 class="fw-semibold mb-3">Додај нова награда</h5>

                    <form asp-action="AddAward" method="post" class="row g-3">
                        @Html.AntiForgeryToken()

                        <input type="hidden" name="ProductId" value="@Model.Id" />

                        <div class="col-12">
                            <label class="form-label">Име на натпревар</label>
                            <input type="text" name="CompetitionName" class="form-control" required />
                        </div>

                        <div class="col-md-7">
                            <label class="form-label">Награда</label>
                            <select name="AwardName" class="form-select" required>
                                <option value="">Избери награда</option>
                                <option value="Gold">Златна</option>
                                <option value="Silver">Сребрена</option>
                                <option value="Bronze">Бронзена</option>
                                <option value="Best of Show">Best of Show</option>
                            </select>
                        </div>

                        <div class="col-md-5">
                            <label class="form-label">Година</label>
                            <input type="number" name="AwardYear" class="form-control" />
                        </div>

                        <div class="col-12">
                            <button type="submit" class="btn btn-dark rounded-pill px-4">
                                Додај награда
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- RIGHT: Form -->
        <div class="col-lg-7">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <form asp-action="Edit" class="needs-validation" novalidate>
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="ProductName" class="form-label fw-semibold"></label>
                            <input asp-for="ProductName" class="form-control form-control-lg" placeholder="Пр. Merlot" />
                            <span asp-validation-for="ProductName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ProductImage" class="form-label fw-semibold">Product Image URL</label>
                            <input asp-for="ProductImage" class="form-control" id="imageUrlInput" placeholder="https://…" />
                            <span asp-validation-for="ProductImage" class="text-danger"></span>
                            <div class="form-text">Стави валидно URL за слика – preview-то лево се освежува веднаш.</div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ProductDescription" class="form-label fw-semibold"></label>
                            <textarea asp-for="ProductDescription" class="form-control" rows="3" placeholder="Краток опис"></textarea>
                            <span asp-validation-for="ProductDescription" class="text-danger"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-4">
                                <label asp-for="Price" class="form-label fw-semibold">Price</label>
                                <div class="input-group">
                                    <span class="input-group-text">ден</span>
                                    <input asp-for="Price" class="form-control" inputmode="numeric" />
                                </div>
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Rating" class="form-label fw-semibold">Rating (0–5)</label>
                                <select asp-for="Rating" class="form-select">
                                    @for (var r = 0; r <= 5; r++)
                                    {
                                        <option value="@r">@r</option>
                                    }
                                </select>
                                <span asp-validation-for="Rating" class="text-danger"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Quantity" class="form-label fw-semibold"></label>
                                <input asp-for="Quantity" class="form-control" inputmode="numeric" />
                                <span asp-validation-for="Quantity" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Color" class="form-label fw-semibold">Категорија</label>
                                <select asp-for="Color" class="form-select">
                                    <option value="">Избери категорија</option>
                                    <option value="Red">Црвена</option>
                                    <option value="White">Бела</option>
                                    <option value="Rose">Розе</option>
                                    <option value="Sparkling">Пенливо</option>
                                </select>
                                <span asp-validation-for="Color" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Year" class="form-label fw-semibold">Year</label>
                                <input asp-for="Year" type="number" class="form-control" />
                                <span asp-validation-for="Year" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary px-4">Save</button>
                            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Details</a>
                            <a asp-action="Index" class="btn btn-light">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Image Modal (Zoom) -->
<div class="modal fade" id="imageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content border-0">
            <div class="modal-body p-0">
                <img id="productPreviewModal"
                     src="@(string.IsNullOrWhiteSpace(Model?.ProductImage) ? "https://via.placeholder.com/1400x900?text=No+Image" : Model.ProductImage)"
                     alt="Product image large"
                     class="w-100 h-auto rounded-3" />
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Затвори</button>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

<style>
    .text-wine {
        color: #7b2d33;
    }

    .preview-wrap {
        background: #f8f9fa;
        border-radius: 14px;
        padding: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 360px;
    }

    .preview-image {
        max-height: 520px;
        object-fit: contain;
        transition: transform .2s ease;
    }

        .preview-image:hover {
            transform: scale(1.01);
            box-shadow: 0 12px 28px rgba(0,0,0,.12);
        }

    .form-label {
        margin-bottom: .35rem;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        (function(){
            const input = document.getElementById('imageUrlInput');
            const preview = document.getElementById('productPreview');
            const previewModal = document.getElementById('productPreviewModal');

            if (!input || !preview) return;

            input.addEventListener('input', () => {
                const url = input.value?.trim();
                if (url && /^https?:\/\/.+/i.test(url)) {
                    preview.src = url;
                    if (previewModal) previewModal.src = url;
                }
            });

            const fallback = 'https://via.placeholder.com/800x600?text=No+Image';
            preview.addEventListener('error', () => { preview.src = fallback; });
            if (previewModal) {
                previewModal.addEventListener('error', () => {
                    previewModal.src = 'https://via.placeholder.com/1400x900?text=No+Image';
                });
            }
        })();
    </script>
}